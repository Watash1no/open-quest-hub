{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Quest Hub",
  "version": "1.0.0",
  "identifier": "dev.openquest.hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open Quest Hub",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "deb",
      "appimage",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "resources/dmg-background.tiff",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 150,
          "y": 220
        },
        "applicationFolderPosition": {
          "x": 510,
          "y": 220
        }
      }
    },
    "resources": []
  }
}
